# BrawlReport API — Environment Variables
# Copy this file to .env and fill in real values (never commit .env to git).

# ─── Brawl Stars API ──────────────────────────────────────────────────────────

# Comma-separated list of Brawl Stars API bearer tokens.
# Obtain tokens at https://developer.brawlstars.com — each token is locked to
# one or more whitelisted IP addresses. At least one token is required.
# Multiple tokens are rotated round-robin for higher throughput.
BS_API_TOKENS=your-token-here,optional-second-token

# Base URL for the Brawl Stars API. Override only when pointing at a local mock.
# Default: https://api.brawlstars.com/v1
#BS_API_BASE_URL=https://api.brawlstars.com/v1

# Maximum requests per second per API token (token-bucket rate limiter).
# Conservative default is 10; increase only if you have confirmed higher limits.
# Default: 10
#BS_API_RATE_PER_TOKEN=10

# ─── Server ───────────────────────────────────────────────────────────────────

# HTTP listen port.
# Default: 8080
#PORT=8080

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log verbosity level: debug | info | warn | error
# "debug" uses a human-readable text format; all other levels use JSON.
# Default: info
#LOG_LEVEL=info
